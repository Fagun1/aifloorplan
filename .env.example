# ============================================================
# AI Architectural Planning Platform — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Database (Neon PostgreSQL connection string)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Google Gemini LLM
GOOGLE_API_KEY=your-google-api-key-here
LLM_MODEL=gemini-1.5-flash
LLM_TEMPERATURE=0.3

# JWT Auth
JWT_SECRET=change-this-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# App
APP_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Redis (optional for Phase 4 caching; leave empty to disable)
REDIS_URL=

# Feature Flags
ENABLE_QUESTION_ENGINE=true
MAX_CANDIDATES_PER_GENERATION=20
MAX_FLOORS=20
